        "jsonBody": "={\n  \"title\": \"{{ $('Get row(s) in sheet').item.json.Title }}\",\n  \"description\": {{ JSON.stringify($json.content_clean) }},\n  \"medias\": [],\n  \"topic\": \"lifestyle\",\n  \"type\": \"text\",\n  \"accountId\": \"{{ $('Get row(s) in sheet').item.json['ID Account'] }}\",\n  \"scheduleAt\": \"{{ $json.schedule_at }}\"\n}",
