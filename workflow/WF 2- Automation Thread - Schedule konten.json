    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $json['Schedule'];\nconst content = $json['Content'] || \"\";\n\n// contoh Schedule: \"05/21/2026 12:00\"\n\n// ======================\n// Convert Schedule ke ISO UTC\n// ======================\nconst [datePart, timePart] = input.split(' ');\nconst [month, day, year] = datePart.split('/');\nconst [hour, minute] = timePart.split(':');\n\n// WIB = UTC+7\n// jadi dikurangi 7 jam agar jadi UTC\nconst date = new Date(Date.UTC(\n  Number(year),\n  Number(month) - 1,\n  Number(day),\n  Number(hour) - 7,\n  Number(minute)\n));\n\n// ======================\n// Clean Content\n// Hapus bagian:\n// [Skor Viral: ...]\n// ======================\nconst cleanContent = content\n  .replace(/\\n?\\[Skor Viral:.*?\\]$/s, '')\n  .trim();\n\nreturn {\n  schedule_at: date.toISOString(),\n  content_clean: cleanContent\n};"
      },
      "type": "n8n-nodes-base.code",
