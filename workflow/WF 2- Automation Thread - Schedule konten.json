    {
      "parameters": {
        "jsCode": "const item = $('Get row(s) in sheet').item.json;\n\n// ======================\n// Clean [ ... ]\n// ======================\nconst cleanedContent = item.Content\n  .replace(/\\[.*?\\]/gs, '')\n  .trim();\n\n// ======================\n// Split Thread Content\n// ======================\nconst rawPosts = cleanedContent\n  .split(/POST\\s+\\d+\\/:/)\n  .map(v => v.trim())\n  .filter(v => v);\n\nconst mainPost = rawPosts[0];\n\nconst replies = rawPosts.slice(1).map(reply => ({\n  description: reply,\n  type: \"text\",\n  medias: []\n}));\n\n// ======================\n// Convert Schedule ke ISO UTC\n// ======================\nconst input = item.Schedule;\n\nconst [datePart, timePart] = input.split(' ');\nconst [month, day, year] = datePart.split('/');\nconst [hour, minute] = timePart.split(':');\n\n// WIB -> UTC\nconst localDate = new Date(Date.UTC(\n  parseInt(year),\n  parseInt(month) - 1,\n  parseInt(day),\n  parseInt(hour) - 7,\n  parseInt(minute)\n));\n\nconst scheduleAt = localDate.toISOString();\n\n// ======================\n// Final Output\n// ======================\nreturn [\n  {\n    json: {\n      description: mainPost,\n      topic: item.Persona || \"\",\n      type: \"text\",\n      medias: [],\n      replies,\n      accountId: item[\"ID Account\"],\n      scheduleAt\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
