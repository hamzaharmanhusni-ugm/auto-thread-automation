# ============ Supabase ============
NEXT_PUBLIC_SUPABASE_URL=https://eyeosyczcazkwhmxaekw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key      # server only, never expose to browser

# ============ AI provider abstraction (default: gemini) ============
AI_PROVIDER_DEFAULT=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash        # override model bila perlu (mis. gemini-2.5-flash)
GEMINI_EMBED_MODEL=text-embedding-004
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============ Repliz (global default; per-workspace overrides live in DB) ============
REPLIZ_BASE_URL=https://api.repliz.com
REPLIZ_USERNAME=
REPLIZ_PASSWORD=
REPLIZ_WEBHOOK_SECRET=

# ============ App ============
APP_URL=http://localhost:3000

# Registration policy (n8n-style): when "false", public sign-up is disabled and
# new members join only via admin invite links. The very first user always
# bootstraps as admin regardless of this flag.
USER_ALLOW_REGISTRATION=false
USER_EMAIL_DEFAULT=
# Optional: MCP server bearer token (enables /api/mcp)
MCP_AUTH_TOKEN=
